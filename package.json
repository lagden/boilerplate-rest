{
  "name": "boilerplate-rest",
  "version": "1.0.0",
  "repository": "github:lagden/boilerplate-rest",
  "description": "Boilerplate para desenvolvimento de uma API REST.",
  "keywords": [
    "api",
    "rest",
    "boilerplate"
  ],
  "type": "module",
  "main": "cli/run.js",
  "files": [
    "cli",
    "server",
    "README.md"
  ],
  "author": "Thiago Lagden",
  "license": "MIT",
  "scripts": {
    "eslint": "eslint --ignore-path .gitignore .",
    "pretest": "npm run eslint",
    "test": "c8 --reporter=text --reporter=text-summary --reporter=lcovonly --reporter=cobertura ava --tap",
    "dev": "run-s test start",
    "start": "cli/run.js"
  },
  "dependencies": {
    "@koa/router": "12.0.0",
    "@tadashi/debug": "4.0.0",
    "@tadashi/koa-base": "5.1.2",
    "@tadashi/local-access": "1.1.0",
    "koa": "2.14.2",
    "koa-bodyparser": "4.4.1",
    "koa-compose": "4.1.0"
  },
  "devDependencies": {
    "@tadashi/hex-id": "2.0.0",
    "ava": "5.3.1",
    "c8": "8.0.1",
    "eslint": "8.48.0",
    "eslint-plugin-unicorn": "48.0.1",
    "eslint-plugin-sonarjs": "0.21.0",
    "got": "13.0.0",
    "hash-to-port": "1.2.0",
    "npm-run-all": "4.1.5"
  }
}
