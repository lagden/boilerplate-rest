{
  "bin": "./cli/run.js",
  "type": "module",
  "scripts": {
    "eslint": "eslint --ignore-path .gitignore .",
    "lint": "prettier --check . && npm run eslint",
    "format": "prettier --write .",
    "pretest": "npm run lint",
    "test": "c8 --reporter=text --reporter=text-summary --reporter=lcovonly --reporter=cobertura node --test test/*.spec.js",
    "dev": "run-s test start",
    "start": "./cli/run.js"
  },
  "dependencies": {
    "@koa/router": "12.0.1",
    "@tadashi/common": "4.x",
    "@tadashi/debug": "4.x",
    "@tadashi/ee": "1.x",
    "@tadashi/koa-base": "5.x",
    "@tadashi/local-access": "1.x",
    "@xet/log-google": "1.x",
    "koa": "2.14.2",
    "koa-bodyparser": "4.4.1",
    "koa-compose": "4.1.0"
  },
  "devDependencies": {
    "c8": "8.0.1",
    "eslint": "8.56.0",
    "eslint-plugin-unicorn": "50.0.1",
    "eslint-plugin-sonarjs": "0.23.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.1.1",
    "test-listen": "1.1.0"
  }
}
